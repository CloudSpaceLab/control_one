# Production environment for control-one.cloudspacetechs.com.
# Copy to .env on the host and fill in.

POSTGRES_USER=controlone
POSTGRES_PASSWORD=replace_me_with_a_strong_password
POSTGRES_DB=controlone

# 32 random bytes hex (64 chars). Generate with:
#   openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=replace_me_64_hex_chars

# Bootstrap token used to enrol the first tenant + admin. Rotate after first run.
BOOTSTRAP_TOKEN=replace_me_with_a_long_random_string

# Small-fleet/demo analytics is the default. Set ANALYTICS_MODE=olap and
# DORIS_ENABLED=true, then run compose with --profile olap, for dedicated
# Doris-backed analytic deployments.
ANALYTICS_MODE=small
ANALYTICS_SQLITE_CACHE_MB=16

# Demo-light hot-state budget. Redis is acceleration/coordination, not the
# evidence store, so keep it bounded and let SQLite/Postgres hold replayable
# analytic facts.
REDIS_MAXMEMORY=128mb
REDIS_MEMORY_LIMIT=192m

# Apache Doris admin password - generated automatically by deploy.py and
# persisted in .secrets.json so re-runs reuse the same value.
DORIS_PASSWORD=replace_me_with_a_strong_password
DORIS_ENABLED=false

# Image tag built from CI. "latest" works for the bootstrap deploy.
TAG=latest
